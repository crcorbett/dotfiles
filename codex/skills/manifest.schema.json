{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crcorbett.dev/schemas/codex-skill-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sourceRepository", "sourcePath", "installedProjections", "projectionDigest", "skills"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "sourceRepository": { "type": "string", "format": "uri" },
    "sourcePath": { "const": "codex/skills" },
    "installedProjections": {
      "type": "array",
      "prefixItems": [
        {
          "const": {
            "id": "agents",
            "path": "~/.agents/skills",
            "role": "primary"
          }
        },
        {
          "const": {
            "id": "codex",
            "path": "~/.codex/skills",
            "role": "compatibility"
          }
        }
      ],
      "items": false,
      "minItems": 2
    },
    "projectionDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "skills": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "fileCount", "treeDigest"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "fileCount": { "type": "integer", "minimum": 1 },
          "treeDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
