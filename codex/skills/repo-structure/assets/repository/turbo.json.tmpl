{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": { "dependsOn": ["^build"], "outputs": ["dist/**", ".output/**"] },
    "check-types": { "dependsOn": ["^build", "^check-types"] },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "test/**", "**/*.test.ts", "**/*.test.tsx"]
    },
    "dev": { "cache": false, "persistent": true }
  }
}
