{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schemaVersion", "tasks"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "owner",
          "claim",
          "acceptance",
          "verification",
          "proof",
          "rollback",
          "maintenance"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pending", "in-progress", "blocked", "completed", "superseded"] },
          "owner": { "type": "string", "minLength": 1 },
          "claim": { "type": "string", "minLength": 1 },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "verification": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "proof": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "rollback": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "maintenance": {
            "type": "object",
            "required": ["owner", "reviewTrigger", "retireWhen"],
            "properties": {
              "owner": { "type": "string", "minLength": 1 },
              "reviewTrigger": { "type": "string", "minLength": 1 },
              "retireWhen": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
