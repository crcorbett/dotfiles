{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "journeys"],
  "properties": {
    "version": { "const": 1 },
    "journeys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "owner",
          "entrypoint",
          "observableOutcome",
          "verification",
          "evidenceOwner",
          "limitations"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "entrypoint": { "type": "string", "minLength": 1 },
          "observableOutcome": { "type": "string", "minLength": 1 },
          "verification": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "evidenceOwner": { "type": "string", "minLength": 1 },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
