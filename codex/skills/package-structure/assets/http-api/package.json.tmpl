{
  "name": "__PACKAGE_NAME__",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./api": {
      "__SOURCE_CONDITION__": "./src/api.ts",
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./group": {
      "__SOURCE_CONDITION__": "./src/group.ts",
      "types": "./dist/group.d.ts",
      "default": "./dist/group.js"
    },
    "./handlers": {
      "__SOURCE_CONDITION__": "./src/handlers.ts",
      "types": "./dist/handlers.d.ts",
      "default": "./dist/handlers.js"
    },
    "./server": {
      "__SOURCE_CONDITION__": "./src/server.ts",
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client/service": {
      "__SOURCE_CONDITION__": "./src/client/service.ts",
      "types": "./dist/client/service.d.ts",
      "default": "./dist/client/service.js"
    },
    "./client/browser": {
      "__SOURCE_CONDITION__": "./src/client/browser.layer.ts",
      "types": "./dist/client/browser.layer.d.ts",
      "default": "./dist/client/browser.layer.js"
    },
    "./client/in-process": {
      "__SOURCE_CONDITION__": "./src/client/in-process.layer.ts",
      "types": "./dist/client/in-process.layer.d.ts",
      "default": "./dist/client/in-process.layer.js"
    },
    "./testing": {
      "__SOURCE_CONDITION__": "./src/testing.ts",
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "publishConfig": {
    "exports": {
      "./api": {
        "types": "./dist/api.d.ts",
        "default": "./dist/api.js"
      },
      "./group": {
        "types": "./dist/group.d.ts",
        "default": "./dist/group.js"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "./client/service": {
        "types": "./dist/client/service.d.ts",
        "default": "./dist/client/service.js"
      },
      "./client/browser": {
        "types": "./dist/client/browser.layer.d.ts",
        "default": "./dist/client/browser.layer.js"
      },
      "./client/in-process": {
        "types": "./dist/client/in-process.layer.d.ts",
        "default": "./dist/client/in-process.layer.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "__DOMAIN_PACKAGE__": "workspace:*",
    "effect": "__EFFECT_VERSION__"
  },
  "devDependencies": {
    "@effect/vitest": "__EFFECT_VERSION__",
    "typescript": "__VERSION_TYPESCRIPT__",
    "vitest": "__VERSION_VITEST__"
  }
}
