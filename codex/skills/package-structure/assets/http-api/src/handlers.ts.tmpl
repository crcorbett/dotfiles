import { __DOMAIN_SYMBOL__Service } from "__DOMAIN_PACKAGE__/service";
import { Effect } from "effect";
import { HttpApiBuilder as EffectHttpApiBuilder } from "effect/unstable/httpapi";

import { __SYMBOL__Api } from "./api";

export const __SYMBOL__HandlersLive = EffectHttpApiBuilder.group(
  __SYMBOL__Api,
  "domain",
  (handlers) =>
    Effect.gen(function* () {
      const domain = yield* __DOMAIN_SYMBOL__Service;
      return handlers
        .handle("list", () => domain.list())
        .handle("get", ({ params }) => domain.get(params.id));
    }),
);
