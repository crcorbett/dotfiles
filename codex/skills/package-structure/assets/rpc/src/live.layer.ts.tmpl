import { Effect, Layer } from "effect";
import { FetchHttpClient } from "effect/unstable/http";
import { RpcClient as EffectRpcClient, RpcSerialization } from "effect/unstable/rpc";

import { __SYMBOL__Group } from "./group";
import { __SYMBOL__Client } from "./service";

export const __SYMBOL__ClientLive = Layer.effect(__SYMBOL__Client)(
  EffectRpcClient.make(__SYMBOL__Group).pipe(
    Effect.map((client) =>
      __SYMBOL__Client.of({
        get: (id) => client.Get__DOMAIN_SYMBOL__({ id }),
        list: () => client.List__DOMAIN_SYMBOL__(),
      }),
    ),
  ),
).pipe(
  Layer.provide(EffectRpcClient.layerProtocolHttp({ url: "/rpc" })),
  Layer.provide(FetchHttpClient.layer),
  Layer.provide(RpcSerialization.layerNdjson),
);
