import { assert, describe, it } from "@effect/vitest";
import { Effect, Layer } from "effect";
import { __DOMAIN_SYMBOL__Live } from "__DOMAIN_PACKAGE__/live";

import { __SYMBOL__Client } from "../src/service";
import { __SYMBOL__ClientTest } from "../src/test.layer";

describe("__SYMBOL__ RPC", () => {
  it.effect("lists through the in-process client", () =>
    Effect.gen(function* () {
      const client = yield* __SYMBOL__Client;
      const items = yield* client.list();
      assert.isArray(items);
    }).pipe(Effect.provide(__SYMBOL__ClientTest.pipe(Layer.provide(__DOMAIN_SYMBOL__Live)))),
  );
});
