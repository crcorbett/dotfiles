import { assert, describe, it } from "@effect/vitest";
import { Effect } from "effect";

import { example__SYMBOL__ } from "../src/__testing__/fixtures";
import { __SYMBOL__Service } from "../src/service";
import { make__SYMBOL__Test } from "../src/test.layer";

describe("__SYMBOL__Service", () => {
  it.effect("uses the deterministic Layer", () =>
    Effect.gen(function* () {
      const setup = yield* make__SYMBOL__Test([example__SYMBOL__]);
      const item = yield* Effect.gen(function* () {
        const service = yield* __SYMBOL__Service;
        return yield* service.get(example__SYMBOL__.id);
      }).pipe(Effect.provide(setup.layer));
      assert.strictEqual(item.name, "Example");
    }),
  );
});
