{
  "name": "__PACKAGE_NAME__",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./schemas": {
      "__SOURCE_CONDITION__": "./src/schemas.ts",
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./errors": {
      "__SOURCE_CONDITION__": "./src/errors.ts",
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./service": {
      "__SOURCE_CONDITION__": "./src/service.ts",
      "types": "./dist/service.d.ts",
      "default": "./dist/service.js"
    },
    "./live": {
      "__SOURCE_CONDITION__": "./src/live.layer.ts",
      "types": "./dist/live.layer.d.ts",
      "default": "./dist/live.layer.js"
    },
    "./test": {
      "__SOURCE_CONDITION__": "./src/test.layer.ts",
      "types": "./dist/test.layer.d.ts",
      "default": "./dist/test.layer.js"
    },
    "./testing/fixtures": {
      "__SOURCE_CONDITION__": "./src/__testing__/fixtures.ts",
      "types": "./dist/__testing__/fixtures.d.ts",
      "default": "./dist/__testing__/fixtures.js"
    },
    "./testing/observations": {
      "__SOURCE_CONDITION__": "./src/__testing__/observations.ts",
      "types": "./dist/__testing__/observations.d.ts",
      "default": "./dist/__testing__/observations.js"
    }
  },
  "publishConfig": {
    "exports": {
      "./schemas": {
        "types": "./dist/schemas.d.ts",
        "default": "./dist/schemas.js"
      },
      "./errors": {
        "types": "./dist/errors.d.ts",
        "default": "./dist/errors.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "default": "./dist/service.js"
      },
      "./live": {
        "types": "./dist/live.layer.d.ts",
        "default": "./dist/live.layer.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "effect": "__EFFECT_VERSION__"
  },
  "devDependencies": {
    "@effect/vitest": "__EFFECT_VERSION__",
    "typescript": "__VERSION_TYPESCRIPT__",
    "vitest": "__VERSION_VITEST__"
  }
}
