import { Effect, Layer, Option } from "effect";

import { __SYMBOL__NotFoundError } from "./errors";
import type { __SYMBOL__Item } from "./schemas";
import { __SYMBOL__Service } from "./service";

const items: readonly __SYMBOL__Item[] = [];

export const __SYMBOL__Live = Layer.succeed(__SYMBOL__Service, {
  get: (id) =>
    Option.fromUndefinedOr(items.find((item) => item.id === id)).pipe(
      Option.match({
        onNone: () => Effect.fail(new __SYMBOL__NotFoundError({ id })),
        onSome: Effect.succeed,
      }),
    ),
  list: () => Effect.succeed(items),
});
